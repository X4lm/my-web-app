{
  "name": "functions",
  "version": "1.0.0",
  "private": true,
  "description": "Bait to Maintain — Cloud Functions (advisor agent + seed tools)",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint --ext .ts src/",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "seed:legal": "node --experimental-specifier-resolution=node lib/legal/seed.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.5.0"
  }
}
