rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      let data = userDoc();
      return data != null ? data.role : 'owner';
    }

    function isSuspended() {
      let data = userDoc();
      return data != null && data.suspended == true;
    }

    function isActive() {
      return isSignedIn() && !isSuspended();
    }

    function isAdmin() {
      return isActive() && getUserRole() == 'admin';
    }

    function isOwnerOf(uid) {
      return isActive() && request.auth.uid == uid;
    }

    function isOwnerOrAdmin(uid) {
      return isOwnerOf(uid) || isAdmin();
    }

    function selfUpdateAllowed() {
      let forbidden = ['role', 'suspended', 'createdAt', 'uid', 'email'].toSet();
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(forbidden);
    }

    // ─── User profiles ───────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && selfUpdateAllowed()) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── User-owned subcollections (settings, vendors, auditLogs, etc.) ──
    match /users/{userId}/settings/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    match /users/{userId}/vendors/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read: if isAdmin();
    }
    match /users/{userId}/auditLogs/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ─── Invitations ─────────────────────────────────────────────────
    // Read uses isSignedIn() not isActive() so new signups can check invitations
    match /invitations/{invitationId} {
      allow read: if isSignedIn() && (
        resource.data.inviterUid == request.auth.uid ||
        resource.data.inviteeEmail == request.auth.token.email ||
        isAdmin()
      );
      allow create: if isActive() &&
        getUserRole() in ['admin', 'owner', 'property_manager'] &&
        request.resource.data.inviterUid == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.inviterUid == request.auth.uid ||
        resource.data.inviteeEmail == request.auth.token.email ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── Properties & subcollections ─────────────────────────────────
    match /users/{userId}/properties/{propertyId} {
      // Owner/admin: full access
      allow read, write: if isOwnerOrAdmin(userId);

      // Linked users (PM, staff, vendor, tenant): read if property is in their linkedProperties
      allow read: if isActive()
        && getUserRole() in ['property_manager', 'staff', 'vendor', 'tenant']
        && propertyId in userDoc().linkedProperties;

      // Property managers: write access to property doc
      allow write: if isActive()
        && getUserRole() == 'property_manager'
        && propertyId in userDoc().linkedProperties;

      match /{subcollection}/{docId} {
        allow read, write: if isOwnerOrAdmin(userId);

        // Linked users: read subcollections
        allow read: if isActive()
          && getUserRole() in ['property_manager', 'staff', 'vendor', 'tenant']
          && propertyId in userDoc().linkedProperties;

        // Property managers & staff: write to subcollections
        allow write: if isActive()
          && getUserRole() in ['property_manager', 'staff']
          && propertyId in userDoc().linkedProperties;
      }
    }

    // ─── Tenants collection ──────────────────────────────────────────
    match /users/{userId}/tenants/{tenantId} {
      allow read, write: if isOwnerOrAdmin(userId);
      allow read: if isActive()
        && getUserRole() in ['property_manager', 'staff'];
    }

    // ─── Mail (Firebase Trigger Email extension) ─────────────────────
    match /mail/{mailId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // ─── Platform settings ───────────────────────────────────────────
    match /platformSettings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Property index (lookup property → owner) ────────────────────
    match /propertyIndex/{propertyId} {
      allow read: if isSignedIn();
      allow write: if isActive() && getUserRole() in ['admin', 'owner'];
    }

    // ─── Analytics ───────────────────────────────────────────────────
    match /analytics/{docId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ─── Login events ────────────────────────────────────────────────
    match /loginEvents/{docId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ─── Support chat (user ↔ admin) ─────────────────────────────────
    // Each user has one thread doc at supportChats/{userId} with messages subcollection.
    // Users can read/write their own thread; admin can read/write all.
    match /supportChats/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.userId == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        // A user may only post messages tagged from='user'; admin may only post from='admin'.
        allow create: if isSignedIn() && (
          (request.auth.uid == userId
            && request.resource.data.from == 'user'
            && request.resource.data.senderUid == request.auth.uid)
          || (isAdmin() && request.resource.data.from == 'admin')
        );
        allow update, delete: if isAdmin();
      }
    }

    // ─── Data Requests (PDPL compliance) ─────────────────────────────
    match /dataRequests/{requestId} {
      allow create: if isActive() && request.resource.data.userId == request.auth.uid;
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── Deny everything else ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
