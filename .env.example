# ─── Firebase Configuration ───
# Get these from your Firebase Console → Project Settings → Web App
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Admin Seed ───
# Set this to the email address of the first admin user.
# When this user signs up or logs in, they will automatically
# be assigned the 'admin' role. This is the recommended way
# to bootstrap your first admin account.
#
# Example: VITE_ADMIN_EMAIL=admin@yourcompany.com
VITE_ADMIN_EMAIL=
